{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Captured lead information for ebook downloads",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the lead"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the lead"
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the lead"
        },
        "createdAt": {
          "type": "integer",
          "description": "Timestamp of capture"
        },
        "emailSent": {
          "type": "boolean",
          "description": "Whether the delivery email was sent"
        },
        "emailSentError": {
          "type": "string",
          "description": "Error message if email delivery failed"
        }
      },
      "required": ["name", "email", "phone", "createdAt", "emailSent"]
    },
    "ProfileSettings": {
      "title": "ProfileSettings",
      "description": "Admin profile and email settings",
      "type": "object",
      "properties": {
        "authorName": {
          "type": "string",
          "description": "Display name of the author in emails"
        },
        "profilePictureBase64": {
          "type": "string",
          "description": "Base64 string representation of custom profile photo"
        },
        "updatedAt": {
          "type": "integer",
          "description": "Timestamp of the last profile update"
        }
      },
      "required": ["authorName"]
    }
  },
  "firestore": {
    "leads": {
      "schema": "Lead",
      "description": "Collection of captured leads"
    },
    "settings": {
      "schema": "ProfileSettings",
      "description": "Collection for application global configurations"
    }
  }
}

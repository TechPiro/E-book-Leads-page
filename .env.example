# =========================================================================
#  Environment variables for the E-book Leads page (Vercel deployment)
#  In Vercel: Project -> Settings -> Environment Variables. Do NOT commit real
#  values -- this .example file is the only env file that should be in git.
# =========================================================================

# --- Firebase (lead + settings storage) -------------------------------------
# PREFERRED / SECURE: full service-account JSON as a single line.
# Firebase Console -> Project Settings -> Service accounts -> Generate new private
# key. Paste the entire JSON as ONE line (the \n inside private_key stays as-is).
# When set, the server uses the Admin SDK and you can lock firestore.rules.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# EASIER ALTERNATIVE (recommended if the JSON above won't paste into your dashboard):
# base64-encode the whole service-account file into a single clean line and use this
# instead. Takes precedence over FIREBASE_SERVICE_ACCOUNT when set.
#   Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json")) > sa.txt
#   macOS/Linux:        base64 -w0 service-account.json   (use -b0 on macOS)
# FIREBASE_SERVICE_ACCOUNT_BASE64="eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Iiwi..."

# Firestore database id. This project uses a NAMED (non-default) database.
# Defaults to firebase-applet-config.json's firestoreDatabaseId if omitted.
FIRESTORE_DATABASE_ID="ai-studio-af0b81c8-4316-4daf-b62e-310d8448737a"

# --- Admin dashboard ---------------------------------------------------------
# Password for the hidden /#admin portal. CHANGE THIS from the default.
ADMIN_PASSWORD="use-a-long-random-password"

# Secret used to sign admin session tokens. Use a long random string.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="a-long-random-secret-string"

# --- Email delivery (Gmail SMTP) --------------------------------------------
# Gmail address that sends the e-book.
SMTP_USER="your-email@gmail.com"
# 16-character Gmail App Password (Google Account -> Security -> App passwords),
# NOT your normal password. Enter it without spaces.
SMTP_PASS="xxxxxxxxxxxxxxxx"
# Optional overrides (defaults shown):
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"

# --- Optional ---------------------------------------------------------------
# Public base URL of the deployed site. Only needed if the auto-detected request
# host is wrong; used for the download link inside the delivery email.
# APP_URL="https://your-project.vercel.app"
